unt":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"44"},{"filePath":"55","messages":"56","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"57","usedDeprecatedRules":"44"},{"filePath":"58","messages":"59","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"60","messages":"61","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"62","messages":"63","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"64","messages":"65","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"66","messages":"67","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"68","messages":"69","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"70","messages":"71","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"44"},{"filePath":"72","messages":"73","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/courtdetails/courtdetails.jsx",["74"],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/App.js",["75","76","77","78"],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/Profile/Profile.jsx",["79","80","81","82"],"import React, {useState, useContext, useEffect} from \"react\";\nimport {UserNameIdContext} from '../UserNameId/UserNameIdContext';\nimport Navbar from '../Navbar/Navbar';\nimport Profile_card from './Profile_card';\nimport axios from 'axios';\nimport { Card, Jumbotron } from \"react-bootstrap\";\nimport Foot from '../footer/head3'\nimport {useHistory} from 'react-router-dom';\nfunction card(detail)\n{\n    return(\n        <Profile_card\n        court_name={detail.courtname}\n        booking_time={detail.time}\n    />\n    );\n    \n\n}\nfunction Profile()\n{\n    const [details, setDetails] = useState(['Empty']);\n    const [username, setNameid] = useContext(UserNameIdContext);\n    console.log(\"Hi\");\n    const history = useHistory();\n    if(username === '')\n    {\n        history.push('/');\n    }\n    useEffect(()=>{\n        const request = async()=>{\n            await axios.post('http://localhost:5000/userdetails', {username})\n            .then(res => {\n                const det = res.data.courts;\n                setDetails(det);\n                \n            });\n            \n        }\n        request();\n    }, []);\n    \n    return (      \n        <>\n        <Navbar name={username}/> \n        <Jumbotron style={{margin:\"0px\"}}>\n        <Card bg=\"primary\" text=\"light\" className=\"text-center\" style={{fontSize:\"30px\", textAlign: \"auto\"}}>\n        <Card.Header>Courts Booked</Card.Header>  \n        </Card>\n          {console.log(details)}                                                                                                                                                                                        \n       {(details === ['Empty'] || details === undefined || details.length === 0)?<Profile_card court_name=\"You have not booked any courts yet !!\"/>:details.map(card)}\n       </Jumbotron> \n       <Foot/>\n       </>\n    );\n}\nexport default Profile;                                     ",["83","84"],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/signup/index.jsx",[],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/home/slides.js",[],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/index.js",[],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/payment/payment.jsx",["85","86","87","88"],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/slideshow/slidshow.jsx",[],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/Profile/Profile_card.jsx",["89"],"import axios from \"axios\";\nimport React, {useContext} from \"react\";\nimport { Button, Card } from \"react-bootstrap\";\nimport {UserNameIdContext} from '../UserNameId/UserNameIdContext';\nimport {useHistory} from 'react-router-dom';\nfunction Profile_card(props)\n{\n    const not_booked = \"You have not booked any courts yet !!\";\n    const [username, setNameid] = useContext(UserNameIdContext);\n    const history = useHistory();\n    console.log(\"hi\")\n    const cancel = async (courtname,bookingtime)=> \n    {\n        \n        await axios.post('http://localhost:5000/cancel', {username, courtname,bookingtime})\n          .then((res)=>{\n            console.log(\"Cancelation complete\")\n            console.log(res.data);\n            const success = res.data.ok;\n            history.push({pathname:\"/cancel_result\", state: {success}});\n        });\n    }\n    return (\n        <Card style={{margin: '5px 0px 5px 0px'}}>\n            {(props.court_name === not_booked || props.court_name === undefined)?\n                <Card.Body style={{margin: \"5px\", fontSize:\"20px\"}}>\n                    {not_booked}\n                </Card.Body>:\n                <Card.Body style={{margin: \"5px\", fontSize:\"20px\"}}>\n                    Court Name: {props.court_name}<br/>\n                    Booked on: {props.booking_time}<br/><br/>\n                    <Button onClick={()=>cancel(props.court_name, props.booking_time)} variant=\"danger\">Cancel Booking</Button>\n                </Card.Body>\n            }\n        </Card>\n    );\n}\nexport default Profile_card;","/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/Cards/Cards.jsx",[],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/terms/terms_and_cond.js",[],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/reportWebVitals.js",[],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/Profile/result.jsx",[],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/Cards/Deck.jsx",["90"],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/UserNameId/UserNameIdContext.jsx",[],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/courtdetails/result.jsx",[],"/mnt/c/Users/ragha/OneDrive/Desktop/code/B-sporthood/b-sporthood/src/components/about/index.js",[],{"ruleId":"91","severity":1,"message":"92","line":15,"column":22,"nodeType":"93","messageId":"94","endLine":15,"endColumn":31},{"ruleId":"91","severity":1,"message":"95","line":2,"column":8,"nodeType":"93","messageId":"94","endLine":2,"endColumn":14},{"ruleId":"91","severity":1,"message":"96","line":3,"column":8,"nodeType":"93","messageId":"94","endLine":3,"endColumn":13},{"ruleId":"91","severity":1,"message":"97","line":4,"column":8,"nodeType":"93","messageId":"94","endLine":4,"endColumn":13},{"ruleId":"91","severity":1,"message":"98","line":7,"column":8,"nodeType":"93","messageId":"94","endLine":7,"endColumn":17},{"ruleId":"99","severity":1,"message":"100","line":12,"column":9,"nodeType":"101","endLine":15,"endColumn":7},{"ruleId":"91","severity":1,"message":"92","line":23,"column":22,"nodeType":"93","messageId":"94","endLine":23,"endColumn":31},{"ruleId":"102","severity":1,"message":"103","line":41,"column":8,"nodeType":"104","endLine":41,"endColumn":10,"suggestions":"105"},{"ruleId":"99","severity":1,"message":"100","line":51,"column":82,"nodeType":"101","endLine":51,"endColumn":148},{"ruleId":"106","replacedBy":"107"},{"ruleId":"108","replacedBy":"109"},{"ruleId":"91","severity":1,"message":"110","line":1,"column":16,"nodeType":"93","messageId":"94","endLine":1,"endColumn":24},{"ruleId":"91","severity":1,"message":"111","line":3,"column":9,"nodeType":"93","messageId":"94","endLine":3,"endColumn":13},{"ru